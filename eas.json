{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "environment": "preview",
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "environment": "production",
      "channel": "production",
      "prebuildCommand": "node scripts/copyGoogleServicesForAndroidBuild.js",
      "ios": {
        "scheme": "servicelinkmobile"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
