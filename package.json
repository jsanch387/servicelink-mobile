{
  "name": "servicelink-mobile",
  "version": "1.0.9",
  "main": "index.js",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "npm run lint && npm run format:check",
    "prepare": "husky",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch --runInBand",
    "eas-build-post-install": "node scripts/copyGoogleServicesForAndroidBuild.js",
    "eas:build:ios:preview": "eas build --platform ios --profile preview",
    "eas:update:preview": "eas update --channel preview",
    "eas:update:production": "eas update --channel production --environment production",
    "eas:update:production:1.0.6": "node scripts/easUpdateProduction.js --runtime 1.0.6 --platform all --message \"Production OTA for App Store 1.0.6 users\""
  },
  "dependencies": {
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "@stripe/stripe-terminal-react-native": "^0.0.1-beta.31",
    "@supabase/supabase-js": "^2.104.0",
    "@tanstack/react-query": "^5.95.2",
    "@types/jest": "29.5.14",
    "aes-js": "^3.1.2",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.12",
    "expo-blur": "^55.0.14",
    "expo-clipboard": "~8.0.8",
    "expo-dev-client": "~6.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "^55.0.14",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "^55.0.13",
    "expo-linking": "~8.0.11",
    "expo-media-library": "~18.2.1",
    "expo-notifications": "~0.32.17",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-store-review": "~9.0.9",
    "expo-symbols": "~1.0.8",
    "expo-updates": "~29.0.18",
    "expo-web-browser": "~15.0.10",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-view-shot": "4.0.3",
    "react-native-worklets": "0.5.1",
    "servicelink-tap-to-pay-education": "file:./modules/servicelink-tap-to-pay-education",
    "tailwindcss": "^3.4.19"
  },
  "private": true,
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "eas-cli": "^18.11.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.0"
  },
  "lint-staged": {
    "*.{js,jsx,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{js,jsx}": [
      "eslint --fix"
    ]
  }
}
